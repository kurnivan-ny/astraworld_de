[0m11:36:32.663405 [debug] [Thread-1 (]: On model.astraworld.dm_sales_by_model: /* {"app": "dbt", "dbt_version": "1.7.9", "profile_name": "astraworld", "target_name": "dev", "node_id": "model.astraworld.dm_sales_by_model"} */

      
  
    

  create  table
    `astraworld_dw`.`dm_sales_by_model`
    
    
      as
    
    (
      

WITH filtered_sales AS (
    SELECT *
    FROM `astraworld_dw`.`sales`
    WHERE price IS NOT NULL
      AND invoice_date IS NOT NULL

    
),

base AS (
    SELECT
        vin,
        model,
        invoice_date,
        price,

        CASE
            WHEN price < 250000000 THEN 'LOW'
            WHEN price <= 400000000 THEN 'MEDIUM'
            ELSE 'HIGH'
        END AS class
    FROM filtered_sales
)

SELECT
    DATE_FORMAT(invoice_date, '%Y-%m') AS periode,
    class,
    model,
    COUNT(*) AS unit_terjual,
    SUM(price) AS total,
    NOW() AS _loaded_at
FROM base
GROUP BY
    DATE_FORMAT(invoice_date, '%Y-%m'),
    class,
    model
    )

  
  
